generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(uuid())
  username           String              @unique
  passwordHash       String
  roles              Role[]
  activeRole         Role?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tokenVersion       Int                 @default(0)
  store              Store?
  wallet             Wallet?
  address            Address[]
  walletTransactions WalletTransaction[]
  cartItems          CartItem[]
  orders             Order[]
  deliveryJobs       DeliveryJob[]

  @@map("users")
}

model Wallet {
  id        String   @id @default(uuid())
  balance   Int      @default(0)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wallet")
}

enum TransactionType {
  TOP_UP
  PAYMENT
  REFUND
  DRIVER_EARNING
}

model WalletTransaction {
  id        String          @id @default(uuid())
  amount    Int             @default(0)
  type      TransactionType
  userId    String
  user      User            @relation(references: [id], fields: [userId], onDelete: Cascade)
  createdAt DateTime        @default(now())
}

model Address {
  id          String   @id @default(uuid())
  label       String //@unique
  fullAddress String //@unique
  isDefault   Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model AppReview {
  id           String   @id @default(uuid())
  reviewerName String   @default("Guest")
  rating       Int
  comment      String
  createdAt    DateTime @default(now())

  @@map("app_reviews")
}

enum Role {
  BUYER
  SELLER
  DRIVER
  ADMIN
}

model Store {
  id          String    @id @default(uuid())
  ownerId     String    @unique
  owner       User      @relation(references: [id], fields: [ownerId], onDelete: Cascade)
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orders      Order[]

  @@map("stores")
}

model Product {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Int
  stock       Int
  imageUrl    String

  storeId   String
  store     Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  cartItems CartItem[]
  orderItem OrderItem[]

  @@unique([storeId, name])
  @@map("products")
}

model CartItem {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(references: [id], fields: [productId], onDelete: Cascade)
  userId    String
  user      User     @relation(references: [id], fields: [userId], onDelete: Cascade)
  quantity  Int
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("cart_items")
}

enum DeliveryMethod {
  INSTANT
  NEXT_DAY
  REGULAR
}

enum DeliveryStatus {
  SEDANG_DIKEMAS
  MENUNGGU_PENGIRIM
  SEDANG_DIKIRIM
  PESANAN_SELESAI
  DIKEMBALIKAN
}

enum DiscountType {
  VOUCHER
  PROMO
}

model Order {
  id              String         @id @default(uuid())
  buyerId         String
  buyer           User           @relation(references: [id], fields: [buyerId])
  storeId         String
  store           Store          @relation(references: [id], fields: [storeId])
  deliveryAddress String // ni snapshot, bukan id relation
  deliveryMethod  DeliveryMethod
  deliveryFee     Int
  subTotal        Int
  tax             Int //ppn 12%
  total           Int
  status          DeliveryStatus @default(SEDANG_DIKEMAS)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  //level 4 
  discount     Int           @default(0)
  discountCode String?
  discountType DiscountType?

  orderItem          OrderItem[]
  orderStatusHistory OrderStatusHistory[]
  deliveryJob        DeliveryJob?

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(references: [id], fields: [orderId], onDelete: Cascade)
  productId String
  product   Product @relation(references: [id], fields: [productId])
  price     Int //snapshot harga waktu di catat bukan harga tergantung id
  quantity  Int

  @@map("order_items")
}

model OrderStatusHistory {
  id        String         @id @default(uuid())
  orderId   String
  status    DeliveryStatus
  timestamp DateTime       @default(now())
  order     Order          @relation(fields: [orderId], references: [id])

  @@map("order_status_histories")
}

model Voucher {
  id             String   @id @default(uuid())
  code           String   @unique
  discountValue  Int
  isPercent      Boolean
  expiryDate     DateTime
  remainingUsage Int
  createdAt      DateTime @default(now())

  @@map("vourchers")
}

model Promo {
  id            String   @id @default(uuid())
  code          String   @unique
  discountValue Int
  isPercent     Boolean
  expiryDate    DateTime
  createdAt     DateTime @default(now())

  @@map("promos")
}

enum DeliveryJobStatus {
  AVAILABLE
  TAKEN
  COMPLETED
  CANCELLED
}

model DeliveryJob {
  id        String            @id @default(uuid())
  orderId   String            @unique
  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driverId  String?
  driver    User?             @relation(fields: [driverId], references: [id], onDelete: Cascade)
  status    DeliveryJobStatus @default(AVAILABLE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("delivery_jobs")
}

model SystemConfig {
  id                    String   @id @default("time_config")
  virtualTimeOffsetDays Int      @default(0)
  updatedAt             DateTime @updatedAt

  @@map("system_cofig")
}
