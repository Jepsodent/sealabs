generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(uuid())
  username           String              @unique
  passwordHash       String
  roles              Role[]
  activeRole         Role?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tokenVersion       Int                 @default(0)
  store              Store?
  wallet             Wallet?
  address            Address[]
  walletTransactions WalletTransaction[]
  cartItems          CartItem[]
  orders             Order[]

  @@map("users")
}

model Wallet {
  id        String   @id @default(uuid())
  balance   Int      @default(0)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wallet")
}

enum TransactionType {
  TOP_UP
  PAYMENT
  REFUND
}

model WalletTransaction {
  id        String          @id @default(uuid())
  amount    Int             @default(0)
  type      TransactionType
  userId    String
  user      User            @relation(references: [id], fields: [userId], onDelete: Cascade)
  createdAt DateTime        @default(now())
}

model Address {
  id          String   @id @default(uuid())
  label       String // buat kasih nama ke alamat misal rumah dll
  fullAddress String
  isDefault   Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model AppReview {
  id           String   @id @default(uuid())
  reviewerName String   @default("Guest")
  rating       Int
  comment      String
  createdAt    DateTime @default(now())

  @@map("app_reviews")
}

enum Role {
  BUYER
  SELLER
  DRIVER
  ADMIN
}

model Store {
  id          String    @id @default(uuid())
  ownerId     String    @unique
  owner       User      @relation(references: [id], fields: [ownerId], onDelete: Cascade)
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orders      Order[]

  @@map("stores")
}

model Product {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Int
  stock       Int
  imageUrl    String

  storeId   String
  store     Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  cartItems CartItem[]
  orderItem OrderItem[]

  @@unique([storeId, name])
  @@map("products")
}

model CartItem {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(references: [id], fields: [productId], onDelete: Cascade)
  userId    String
  user      User     @relation(references: [id], fields: [userId], onDelete: Cascade)
  quantity  Int
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

enum DeliveryMethod {
  INSTANT
  NEXT_DAY
  REGULAR
}

model Order {
  id              String         @id @default(uuid())
  buyerId         String
  buyer           User           @relation(references: [id], fields: [buyerId])
  storeId         String
  store           Store          @relation(references: [id], fields: [storeId])
  deliveryAddress String // ni snapshot, bukan id relation
  deliveryMethod  DeliveryMethod
  deliveryFee     Int
  subTotal        Int
  tax             Int //ppn 12%
  total           Int
  status          String         @default("Sedang Dikemas")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  orderItem          OrderItem[]
  orderStatusHistory OrderStatusHistory[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(references: [id], fields: [orderId], onDelete: Cascade)
  productId String
  product   Product @relation(references: [id], fields: [productId])
  price     Int //snapshot harga waktu di catat bukan harga tergantung id
  quantity  Int
}

model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String
  status    String
  timestamp DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}
